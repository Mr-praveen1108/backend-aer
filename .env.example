PORT=5000
# MongoDB Atlas — whitelist your IP in Atlas → Network Access before connecting
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.kpbuffo.mongodb.net/cargo_delivery?appName=Cluster0

# Local development fallback
# MONGODB_URI=mongodb://127.0.0.1:27017/cargo_delivery
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Production: your deployed frontend URL(s) for CORS (comma-separated for multiple)
# FRONTEND_URL=https://your-frontend.vercel.app
# FRONTEND_URLS=https://your-frontend.onrender.com,https://your-frontend.vercel.app

# Optional: OpenAI for AI-powered chatbot (falls back to knowledge base if not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
